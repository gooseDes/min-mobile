{
    "name": "min-mobile",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "android": "react-native run-android --appIdSuffix debug",
        "ios": "react-native run-ios",
        "lint": "eslint .",
        "start": "react-native start",
        "test": "jest",
        "generate_sql": "drizzle-kit generate",
        "assets": "npx react-native-asset",
        "release": "git push origin main:release -f",
        "apk": "export $(grep -v '^#' .env | xargs -d '\n') && cd android && ./gradlew assembleRelease && adb install ./app/build/outputs/apk/release/app-release.apk && cd .."
    },
    "dependencies": {
        "@danielsaraldi/react-native-blur-view": "^2.3.2",
        "@notifee/react-native": "^9.1.8",
        "@op-engineering/op-sqlite": "^15.2.2",
        "@react-native-firebase/app": "^23.7.0",
        "@react-native-firebase/messaging": "^23.7.0",
        "@react-navigation/native": "^7.1.26",
        "@react-navigation/native-stack": "^7.9.0",
        "babel-plugin-module-resolver": "^5.0.2",
        "drizzle-orm": "^0.45.1",
        "react": "19.1.1",
        "react-native": "0.82.1",
        "react-native-dotenv": "^3.4.11",
        "react-native-image-picker": "^8.2.1",
        "react-native-keychain": "^10.0.0",
        "react-native-marked": "^7.1.1",
        "react-native-mmkv": "^4.1.1",
        "react-native-nitro-modules": "^0.33.0",
        "react-native-reanimated": "^4.2.0",
        "react-native-safe-area-context": "^5.5.2",
        "react-native-screens": "^4.19.0",
        "react-native-vector-icons": "^10.3.0",
        "react-native-worklets": "^0.7.1",
        "socket.io-client": "^4.8.1",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@babel/preset-env": "^7.25.3",
        "@babel/runtime": "^7.25.0",
        "@react-native-community/cli": "^20.1.3",
        "@react-native-community/cli-platform-android": "^20.1.3",
        "@react-native-community/cli-platform-ios": "^20.1.3",
        "@react-native/babel-preset": "0.82.1",
        "@react-native/eslint-config": "0.82.1",
        "@react-native/metro-config": "0.82.1",
        "@react-native/typescript-config": "0.82.1",
        "@types/jest": "^29.5.13",
        "@types/react": "^19.1.1",
        "@types/react-native-vector-icons": "^6.4.18",
        "@types/react-test-renderer": "^19.1.0",
        "babel-plugin-inline-import": "^3.0.0",
        "drizzle-kit": "^0.31.8",
        "eslint": "^8.19.0",
        "jest": "^29.6.3",
        "prettier": "2.8.8",
        "prettier-plugin-organize-imports": "^4.3.0",
        "react-native-asset": "^2.3.0",
        "react-test-renderer": "19.1.1",
        "typescript": "^5.8.3"
    },
    "overrides": {
        "esbuild": "0.25.0"
    },
    "engines": {
        "node": ">=20"
    },
    "eslintConfig": {
        "root": true,
        "extends": "@react-native",
        "rules": {
            "react-native/no-inline-styles": "off",
            "react-hooks/exhaustive-deps": "off",
            "@typescript-eslint/no-unused-vars": [
                "error",
                {
                    "varsIgnorePattern": "^_",
                    "argsIgnorePattern": "^_",
                    "caughtErrorsIgnorePattern": "^_",
                    "destructuredArrayIgnorePattern": "^_"
                }
            ]
        }
    }
}
