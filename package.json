{
  "name": "min-mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --appIdSuffix debug --no-packager",
    "ios": "react-native run-ios",
    "start": "npx expo start --dev-client",
    "web": "npx expo start --web",
    "lint": "eslint .",
    "test": "jest",
    "generate_sql": "drizzle-kit generate",
    "assets": "npx react-native-asset",
    "release": "git push origin main:release -f",
    "apk": "export $(grep -v '^#' .env | xargs -d '\n') && cd android && ./gradlew assembleRelease && adb install ./app/build/outputs/apk/release/app-release.apk && cd ..",
    "update_api": "npm i github:gooseDes/min-node-api-client#build --prefer-online",
    "check": "npx tsc --noEmit"
  },
  "dependencies": {
    "@min/api-client": "github:gooseDes/min-node-api-client#build",
    "@notifee/react-native": "^9.1.8",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-firebase/app": "^23.7.0",
    "@react-native-firebase/messaging": "^23.7.0",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "drizzle-orm": "^0.45.1",
    "expo": "~56.0.0",
    "expo-asset": "^56.0.17",
    "expo-file-system": "~56.0.8",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-modules-core": "~56.0.17",
    "expo-sqlite": "^56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-keychain": "^10.0.0",
    "react-native-marked": "^7.1.1",
    "react-native-material-you-colors": "^0.1.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.19.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.1",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "~56.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.19.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react-native-asset": "^2.3.0",
    "react-test-renderer": "19.1.1",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "uuid": ">=11.1.1",
    "joi": "^18.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "eslintConfig": {
    "root": true,
    "extends": "@react-native",
    "rules": {
      "react-native/no-inline-styles": "off",
      "react-hooks/exhaustive-deps": "off",
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "varsIgnorePattern": "^_",
          "argsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_",
          "destructuredArrayIgnorePattern": "^_"
        }
      ]
    }
  },
  "allowScripts": {
    "esbuild@0.25.0": true,
    "@firebase/util@1.14.0": true,
    "protobufjs@7.6.3": true
  }
}
