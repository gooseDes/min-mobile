{
    "extends": "@react-native/typescript-config",
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["**/node_modules", "**/Pods"],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": ["src/components/*"],
            "@pages/*": ["src/pages/*"],
            "@types/*": ["src/types/*"],
            "@drizzle/*": ["drizzle/*"],
            "@/*": ["src/*"]
        }
    }
}
