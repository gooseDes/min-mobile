{
    "extends": "@react-native/typescript-config",
    "include": ["**/*.ts", "**/*.tsx", ".eslintrc"],
    "exclude": ["**/node_modules", "**/Pods"],
    "compilerOptions": {
        "types": ["react-native"],
        "paths": {
            "@app/*": ["./src/app/*"],
            "@components/*": ["./src/components/*"],
            "@types/*": ["./src/types/*"],
            "@services/*": ["./src/services/*"],
            "@db/*": ["./src/db/*"],
            "@drizzle/*": ["./drizzle/*"],
            "@specs/*": ["./src/specs/*"],
            "@contexts/*": ["./src/contexts/*"],
            "@/*": ["./src/*"],
            "@index": ["./index.js"]
        }
    }
}
